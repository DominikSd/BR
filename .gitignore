# Python
__pycache__/
*.pyc
*.pyo
.venv/
*.egg-info/
dist/
build/

# Test and tooling caches
.pytest_cache/
.pytest_tmp/
pytest-temp*/
pytest-cache/
pytest-cache-*/
pytest-cache-files-*/
test-runtime-temp/
data/test-runtime-temp/
.ruff_cache/
.mypy_cache/

# Runtime outputs and local debug artifacts
/data/**
!/data/telemetry/
!/data/telemetry/.gitkeep
/logs/**
!/logs/.gitkeep
/screenshots/

# Local raw capture dumps that are not part of the canonical sample set
/assets/live/sample_frames/raw/[0-9][0-9][0-9]_*.png

# Local ad-hoc live regression screenshots kept only for manual analysis
/assets/live/sample_frames/raw/live_free_*.png
/assets/live/sample_frames/raw/live_occupied_*.png
/assets/live/sample_frames/raw/live_mixed_*.png
/assets/live/sample_frames/raw/live_player_confusion_*.png
/assets/live/sample_frames/raw/live_occluded_*.png

# Local archive/reference templates that should not go into normal commits
/assets/live/templates/archive/
